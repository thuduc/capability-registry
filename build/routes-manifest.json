{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/capabilities/versions/[versionId]/comments",
      "regex": "^/api/capabilities/versions/([^/]+?)/comments(?:/)?$",
      "routeKeys": {
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/capabilities/versions/(?<nxtPversionId>[^/]+?)/comments(?:/)?$"
    },
    {
      "page": "/api/capabilities/versions/[versionId]/diff",
      "regex": "^/api/capabilities/versions/([^/]+?)/diff(?:/)?$",
      "routeKeys": {
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/capabilities/versions/(?<nxtPversionId>[^/]+?)/diff(?:/)?$"
    },
    {
      "page": "/api/capabilities/versions/[versionId]/download",
      "regex": "^/api/capabilities/versions/([^/]+?)/download(?:/)?$",
      "routeKeys": {
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/capabilities/versions/(?<nxtPversionId>[^/]+?)/download(?:/)?$"
    },
    {
      "page": "/api/capabilities/versions/[versionId]/files",
      "regex": "^/api/capabilities/versions/([^/]+?)/files(?:/)?$",
      "routeKeys": {
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/capabilities/versions/(?<nxtPversionId>[^/]+?)/files(?:/)?$"
    },
    {
      "page": "/api/capabilities/versions/[versionId]/status",
      "regex": "^/api/capabilities/versions/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPversionId": "nxtPversionId"
      },
      "namedRegex": "^/api/capabilities/versions/(?<nxtPversionId>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/api/capabilities/[id]",
      "regex": "^/api/capabilities/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/capabilities/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/install/[name]/[version]",
      "regex": "^/api/install/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPname": "nxtPname",
        "nxtPversion": "nxtPversion"
      },
      "namedRegex": "^/api/install/(?<nxtPname>[^/]+?)/(?<nxtPversion>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/tags/[id]",
      "regex": "^/api/tags/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/tags/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/capabilities",
      "regex": "^/api/capabilities(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/capabilities(?:/)?$"
    },
    {
      "page": "/api/capabilities/parse",
      "regex": "^/api/capabilities/parse(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/capabilities/parse(?:/)?$"
    },
    {
      "page": "/api/login",
      "regex": "^/api/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/login(?:/)?$"
    },
    {
      "page": "/api/tags",
      "regex": "^/api/tags(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/tags(?:/)?$"
    },
    {
      "page": "/api/users",
      "regex": "^/api/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/users(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}